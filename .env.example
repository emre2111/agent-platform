# ── Database ────────────────────────────────────────
# Supabase: use the pooler URL (port 6543) with ?pgbouncer=true
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agent_platform?schema=public"

# ── Redis (required for BullMQ job queue) ──────────
# Upstash: use the provided host, port, and password
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Auth ────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── Encryption (AES-256-GCM key for agent credentials)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── App ─────────────────────────────────────────────
PORT=3000

# ── CORS (comma-separated origins for production) ──
# Leave empty for localhost defaults in development
CORS_ORIGINS=
